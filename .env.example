# ============================================================
# Pregonero — Environment Configuration
# Copy this file to .env and fill in all required values.
# NEVER commit .env to version control.
# ============================================================

# --- Groq ---
# API key from https://console.groq.com/
GROQ_API_KEY=

# --- Telegram ---
# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=
# Numeric chat ID where approved articles are sent.
# To find it: message your bot, then call:
# https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_CHAT_ID=

# --- Scheduling ---
# Cron expression (default: 8am every day)
# Standard 5-field cron: minute hour day month weekday
CRON_SCHEDULE=0 8 * * *

# --- AI Limits ---
# Max AI filter calls per run (prevents runaway API spend)
MAX_AI_CALLS_PER_RUN=20
# Milliseconds between consecutive AI calls (rate-limit buffer)
AI_CALL_DELAY_MS=1000

# --- Database ---
DB_PATH=./data/pregonero.db

# --- Behavior ---
# Set to "true" to skip Telegram sends and DB writes (for testing)
DRY_RUN=false
# Log level: debug | info | warn | error
LOG_LEVEL=info
